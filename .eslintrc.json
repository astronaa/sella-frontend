{
  "extends": [
    "next/core-web-vitals",
    "plugin:@typescript-eslint/recommended",
    "plugin:@typescript-eslint/stylistic"
  ],
  "plugins": [
    "@stylistic/js",
    "@typescript-eslint"
  ],
  "rules": {
    "@stylistic/js/indent": ["error", "tab", { "SwitchCase": 1 }],
    "no-restricted-imports": [
      "error",
      {
        "patterns": [
          {
            "group": ["~/shared/api/client/*", "!~/shared/api/client/index.ts"],
            "message": "Please import from public api instead (~/shared/api/client)"
          }
        ]
      }
    ]
  }
}